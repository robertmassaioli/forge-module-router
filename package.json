{
  "name": "forge-module-router",
  "version": "1.1.0",
  "description": "Context-aware routing primitives for Atlassian Forge Custom UI apps",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@forge/bridge": ">=3.0.0",
    "history": ">=5.0.0",
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0",
    "react-router-dom": ">=6.0.0"
  },
  "devDependencies": {
    "@forge/bridge": "^5.11.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "history": "^5.3.0",
    "jsdom": "^29.0.2",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.19.0",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "test:matrix": "tsx test-matrix/runner/run-matrix.ts",
    "test:matrix:quick": "tsx test-matrix/runner/run-matrix.ts --combinations=M1,M2,M6"
  },
  "keywords": [
    "forge",
    "atlassian",
    "router",
    "react",
    "custom-ui",
    "module-router"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/robertmassaioli/forge-module-router"
  }
}
